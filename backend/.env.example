# Rename this file to .env and fill in your real values.
# NEVER commit your real .env file to git.

PORT=4000

# The AI opponent uses chess-api.com (free, Stockfish 18, no API key
# required) — see backend/routes/aiMove.js. Nothing to configure here.
# If you later switch to a provider that DOES require a key, add it here
# and read it in routes/aiMove.js.

# Firebase Admin credentials — used to verify Firebase Auth tokens and to
# read/write Firestore. Get this from Firebase Console > Project settings >
# Service accounts > Generate new private key. Paste the ENTIRE downloaded
# JSON file as a single line here.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Frontend origin(s) allowed to talk to this backend (for CORS + Socket.io).
# Comma-separate multiple origins, e.g. your Vercel production domain plus
# a preview-deployment URL: https://your-app.vercel.app,https://your-app-git-main-you.vercel.app
CLIENT_ORIGIN=http://localhost:5173

# Optional. Postgres connection string (Neon works great here — free tier,
# serverless). Powers Game Review's analysis cache (so re-opening a
# reviewed game is instant instead of re-running Stockfish on every
# position again) and the profile page's move-accuracy analytics. Get this
# from the Neon console after creating a project: Dashboard > Connect >
# copy the connection string. Leave unset and the app runs fine without
# it — Game Review just re-analyzes from scratch each time, and the
# analytics panel on the profile page stays empty. Tables are created
# automatically on first use (see backend/db.js) — nothing to run by hand.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require
