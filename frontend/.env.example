# Rename to .env — these are your Firebase Web app config values, from
# Firebase Console > Project settings > General > Your apps > SDK setup
# and configuration ("Config" option). They're bundled into the browser
# build (that's normal for Firebase web apps — access is controlled by
# Firebase Auth + security rules, not by hiding these values).
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef

# Optional — only needed for avatar photo uploads (Change Photo/Upload
# Photo on the profile page). Find it in Firebase Console > Project
# settings > General > Your apps, or Build > Storage once enabled. Looks
# like your-project.appspot.com or your-project.firebasestorage.app.
# See the README's "Extra setup for avatar uploads" section — Storage
# requires the Blaze (pay-as-you-go) plan to enable at all, even for
# free-tier usage. Leave unset and every other feature still works;
# uploads will just show a clear error until this is set up.
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Where your backend lives (unchanged)
VITE_BACKEND_URL=http://localhost:4000
